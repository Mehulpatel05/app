# Hugging Face API Configuration
HUGGING_FACE_API_KEY=your_hugging_face_api_key_here

# Server Configuration
PORT=3001
NODE_ENV=development
CORS_ORIGIN=http://localhost:3000

# Database
DATABASE_PATH=./data/app.db

# API Timeouts (in milliseconds)
INFERENCE_TIMEOUT=120000
IMAGE_GENERATION_TIMEOUT=60000
VIDEO_GENERATION_TIMEOUT=180000

# Model Endpoints
TEXT_GENERATION_MODEL=mistralai/Mistral-7B-Instruct-v0.1
IMAGE_GENERATION_MODEL=stabilityai/stable-diffusion-2-1
SENTIMENT_ANALYSIS_MODEL=distilbert-base-uncased-finetuned-sst-2-english
OBJECT_DETECTION_MODEL=facebook/detr-resnet-50
VIDEO_ANALYSIS_MODEL=MCG-NJU/VideoMAE-base
VIDEO_GENERATION_MODEL=stabilityai/stable-video-diffusion-img2vid

# Cache Configuration
ENABLE_CACHE=true
CACHE_EXPIRY_HOURS=24

# Replicate Configuration (for advanced video generation)
REPLICATE_API_KEY=optional_replicate_key
